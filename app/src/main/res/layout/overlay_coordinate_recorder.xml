<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/touch_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/indicators_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="@drawable/overlay_card_background"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="#4CAF50"
                android:layout_marginEnd="10dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="坐标记录"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/coordinate_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击屏幕记录坐标"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="90dp"
                android:layout_height="44dp"
                android:text="取消"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_cancel_background"
                android:layout_marginEnd="10dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="90dp"
                android:layout_height="44dp"
                android:text="确认"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_confirm_background"
                android:enabled="false"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="90dp"
                android:layout_height="44dp"
                android:text="重置"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_reset_background"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
